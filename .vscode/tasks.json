{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "💾 Save Context to Obsidian",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "cd ${workspaceFolder}; .\\scripts\\context-saver.ps1 -SessionName 'manual-$(Get-Date -Format yyyy-MM-dd-HHmm)' -Workspace '${workspaceFolder}'"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      },
      "problemMatcher": [],
      "group": {
        "kind": "none",
        "isDefault": false
      }
    },
    {
      "label": "📖 Load Context from Obsidian",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "cd ${workspaceFolder}; .\\scripts\\context-loader.ps1"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      },
      "problemMatcher": [],
      "group": {
        "kind": "none",
        "isDefault": false
      }
    }
  ]
}
